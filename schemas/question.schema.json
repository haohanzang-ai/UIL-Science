{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://haohanzang-ai.github.io/UIL-Science/schemas/question.schema.json",
  "title": "Verified UIL Science Question",
  "type": "object",
  "required": [
    "schemaVersion",
    "questionId",
    "examId",
    "year",
    "questionNumber",
    "subject",
    "stem",
    "choices",
    "officialAnswer",
    "verificationStatus",
    "published",
    "citations",
    "categorization"
  ],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "const": 1 },
    "questionId": { "type": "string", "minLength": 1 },
    "examId": { "type": "string" },
    "year": { "type": "integer" },
    "questionNumber": { "type": "integer", "minimum": 1, "maximum": 60 },
    "subject": { "enum": ["biology", "chemistry", "physics"] },
    "stem": { "type": "string", "minLength": 1 },
    "choices": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } },
    "officialAnswer": { "type": "string", "minLength": 1 },
    "verificationStatus": { "enum": ["verified", "needs-review", "official-key-disputed"] },
    "published": { "type": "boolean" },
    "citations": { "type": "array" },
    "categorization": { "type": "object" }
  }
}
