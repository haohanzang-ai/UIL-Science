# Backend deployment settings. Copy values into your host's environment UI.
NODE_ENV=production
CORS_ORIGINS=https://haohanzang-ai.github.io
ADMIN_TOKEN=replace-with-a-long-random-admin-token

# Optional persistent libSQL/Turso database.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=replace-with-your-turso-token

# Local demo only. Do not enable in production.
# ENABLE_DEMO_COACH_AUTH=false
